# Database Configuration
# PostgreSQL connection string: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://praanlink:praanlink@localhost:5432/praanlink

# Gemini API key (https://aistudio.google.com/apikey) - used directly for OCR/vision calls.
# The AI pipeline (ai-pipeline/.env) needs the same key as GOOGLE_API_KEY.
GEMINI_API_KEY=your_gemini_api_key_here

# URL of the running `adk api_server` (see ai-pipeline/README / project README)
ADK_SERVER_URL=http://localhost:5010

# Hugging Face access token, required for WhisperX speaker diarization
# (pyannote/speaker-diarization-3.0 + pyannote/segmentation-3.0 are gated models -
# accept their terms on huggingface.co, then create a token at
# https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# Optional: Gmail/Calendar integration (doctor escalation feature).
# Requires backend/credentials.json (OAuth2 client) + a one-time run of
# `python utils/google_auth_setup.py` to generate backend/token.json.
GOOGLE_USER_EMAIL=your_sender_gmail_address@gmail.com
GOOGLE_RECEIVER_EMAIL=default_recipient_email@gmail.com
